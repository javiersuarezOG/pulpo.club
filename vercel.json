{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "buildCommand": "npm install --no-audit --no-fund && npm run build",
  "ignoreCommand": "[ \"$VERCEL_GIT_COMMIT_AUTHOR_LOGIN\" = \"pulpo-bot\" ] && exit 0 || exit 1",
  "outputDirectory": ".",
  "functions": {
    "api/social/image.js": {
      "excludeFiles": "web/photos/**,web/photos-hires/**"
    },
    "api/img.js": {
      "excludeFiles": "web/photos/**,web/photos-hires/**"
    }
  },
  "rewrites": [
    { "source": "/",                        "destination": "/web/dist/index.html" },
    { "source": "/legacy",                  "destination": "/web/legacy.html" },
    { "source": "/legacy/",                 "destination": "/web/legacy.html" },
    { "source": "/dashboard",               "destination": "/web/dashboard.html" },
    { "source": "/data/ranked.json",        "destination": "/web/data/ranked.json" },
    { "source": "/data/ranked.list.json",   "destination": "/web/data/ranked.list.json" },
    { "source": "/data/last_updated.json",  "destination": "/web/data/last_updated.json" },
    { "source": "/data/run_history.json",   "destination": "/web/data/run_history.json" },
    { "source": "/data/featured.json",      "destination": "/web/data/featured.json" },
    { "source": "/photos/:file",            "destination": "/web/photos/:file" },
    { "source": "/photos-hires/:file",      "destination": "/web/photos-hires/:file" },
    { "source": "/assets/:file",            "destination": "/web/assets/:file" },
    { "source": "/build/:file",             "destination": "/web/dist/build/:file" },
    { "source": "/terms",                   "destination": "/web/dist/index.html" },
    { "source": "/privacy",                 "destination": "/web/dist/index.html" },
    { "source": "/cookies",                 "destination": "/web/dist/index.html" },
    { "source": "/subscription",            "destination": "/web/dist/index.html" },
    { "source": "/imprint",                 "destination": "/web/dist/index.html" },
    { "source": "/impressum",               "destination": "/web/dist/index.html" },
    { "source": "/contact",                 "destination": "/web/dist/index.html" },
    { "source": "/sitemap.xml",             "destination": "/web/sitemap.xml" },
    { "source": "/robots.txt",              "destination": "/web/robots.txt" },
    { "source": "/browse",                  "destination": "/web/dist/index.html" },
    { "source": "/saved",                   "destination": "/web/dist/index.html" },
    { "source": "/plans",                   "destination": "/web/dist/index.html" },
    { "source": "/account",                 "destination": "/web/dist/index.html" },
    { "source": "/account/:section",        "destination": "/web/dist/index.html" },
    { "source": "/admin",                   "destination": "/web/dist/index.html" },
    { "source": "/admin/:widget",           "destination": "/web/dist/index.html" },
    { "source": "/listing/:id",             "destination": "/web/dist/index.html" },
    { "source": "/start",                   "destination": "/web/dist/index.html" },
    { "source": "/:slug([A-Za-z0-9_-]+)",   "destination": "/web/dist/index.html" }
  ],
  "redirects": [
    { "source": "/legal", "destination": "/terms", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Content-Security-Policy-Report-Only", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://*.clerk.com https://*.clerk.accounts.dev https://eu.i.posthog.com https://eu-assets.i.posthog.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.clerk.com https://*.clerk.accounts.dev https://eu.i.posthog.com https://eu-assets.i.posthog.com https://api.stripe.com; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://*.clerk.com https://*.clerk.accounts.dev; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self' https://checkout.stripe.com; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/data/ranked.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }]
    },
    {
      "source": "/data/ranked.list.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600" }]
    },
    {
      "source": "/data/last_updated.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }]
    },
    {
      "source": "/data/run_history.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }]
    },
    {
      "source": "/data/featured.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, s-maxage=86400" }]
    },
    {
      "source": "/photos/:file",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000, s-maxage=2592000, stale-while-revalidate=604800" }]
    },
    {
      "source": "/photos-hires/:file",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000, s-maxage=2592000, stale-while-revalidate=604800" }]
    },
    {
      "source": "/build/:file",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/assets/:file",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400, stale-while-revalidate=604800" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }]
    }
  ]
}
