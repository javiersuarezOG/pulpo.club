# Copy to .env (or set in Vercel project Settings → Environment Variables).
# Never commit the real values.

# --- Auth (Vercel) ---------------------------------------------------------
# 32+ random bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=replace-me-with-32-or-more-random-chars-please

# Comma-separated "username:bcryptHash" pairs. Use automation/add_user.js to mint each line.
# Example (DO NOT use this, just an illustration):
#   USERS=alice:$2a$10$abc...,bob:$2a$10$xyz...
USERS=

# --- Pipeline (cron + CLI) -------------------------------------------------
PULPO_OFFLINE=0
PULPO_LIMIT=60
PULPO_SOURCES=goodlife,oceanside,kazu

# Optional composite ranker weights (auto-renormalize if they don't sum to 1.0)
# PULPO_W_VALUE=0.35
# PULPO_W_QUALITY=0.25
# PULPO_W_LIQUIDITY=0.20
# PULPO_W_UPSIDE=0.20

# --- Phase 2 ---------------------------------------------------------------
MAPBOX_TOKEN=
DATABASE_URL=postgres://user:pass@localhost:5432/pulpo

# --- PR-9 · Clerk auth (scaffolding behind a flag) -------------------------
# Off by default — when 0/unset the app uses the legacy localStorage user
# (the dev-panel authState toggle still works). Flip to 1 on Vercel
# preview to mount <ClerkProvider>; PR-9b onward wires real call sites
# behind the same flag.
VITE_USE_CLERK=0
# Publishable key from https://dashboard.clerk.com/~/api-keys (React).
# Required when VITE_USE_CLERK=1; ignored otherwise.
VITE_CLERK_PUBLISHABLE_KEY=
# Backend secret from https://dashboard.clerk.com/~/api-keys (Backend).
# Server-only — never exposed to the client. Required for the Stripe
# webhook to update user metadata, and for /api/stripe/create-checkout-session
# to authenticate the request.
CLERK_SECRET_KEY=

# --- PR-9 · Stripe Managed Payments ---------------------------------------
# From https://dashboard.stripe.com → Developers → API keys.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from the Stripe dashboard (Developers →
# Webhooks → endpoint → Signing secret). The endpoint URL points at
# /api/stripe/webhook on your deploy.
STRIPE_WEBHOOK_SECRET=
# Output of `npm run stripe:setup` (creates the Pulpo Pro product +
# default monthly price). Idempotent — safe to re-run.
STRIPE_PRICE_ID_PRO=
