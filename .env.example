# Copy to .env (or set in Vercel project Settings → Environment Variables).
# Never commit the real values.

# (Pre-Clerk legacy paywall env vars SESSION_SECRET + USERS were removed
# in feat/legacy-auth-purge along with the api/login.js + api/members.js
# endpoints. Clerk owns auth end-to-end now — see VITE_USE_CLERK below.)

# --- Pipeline (cron + CLI) -------------------------------------------------
PULPO_OFFLINE=0
PULPO_LIMIT=60
PULPO_SOURCES=goodlife,oceanside,kazu

# Optional composite ranker weights (auto-renormalize if they don't sum to 1.0)
# PULPO_W_VALUE=0.35
# PULPO_W_QUALITY=0.25
# PULPO_W_LIQUIDITY=0.20
# PULPO_W_UPSIDE=0.20

# --- Phase 2 ---------------------------------------------------------------
MAPBOX_TOKEN=

# NOTE: A `DATABASE_URL` stub used to live here. It was never referenced
# in any code path and misled the 2026-05-20 pre-prod audit into asking
# for a backup runbook for a database that doesn't exist. See CLAUDE.md
# §"Persistence & backups" for what Pulpo actually persists where.

# --- Clerk auth (default-on since PR-9d) -----------------------------------
# Clerk is the production auth path. It activates whenever
# VITE_CLERK_PUBLISHABLE_KEY is set and VITE_USE_CLERK is anything other
# than "0". Set VITE_USE_CLERK=0 to keep the legacy localStorage-only
# email/password modal (used by CI and fresh clones with no Clerk key).
VITE_USE_CLERK=
# Publishable key from https://dashboard.clerk.com/~/api-keys (React).
# Use the *production* instance's pk_live_* on Vercel Production; the
# dev instance's pk_test_* is fine on previews and local dev.
VITE_CLERK_PUBLISHABLE_KEY=
# Backend secret from https://dashboard.clerk.com/~/api-keys (Backend).
# Server-only — never exposed to the client. Required by /api/saves,
# /api/stripe/create-checkout-session, /api/stripe/billing-portal, and
# the Stripe webhook for updating user metadata.
CLERK_SECRET_KEY=
# Server-side publishable key. @clerk/backend v3 needs both keys to
# derive the cookie suffix inside authenticateRequest(). Falls back to
# VITE_CLERK_PUBLISHABLE_KEY (Vercel exposes every env var to
# serverless functions regardless of prefix), so setting only the VITE
# variant works — but mirroring it here keeps the server contract
# explicit. See api/_clerk.js for the lookup order.
CLERK_PUBLISHABLE_KEY=

# --- Stripe Managed Payments ----------------------------------------------
# From https://dashboard.stripe.com → Developers → API keys.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from the Stripe dashboard (Developers →
# Webhooks → endpoint → Signing secret). The endpoint URL points at
# /api/stripe/webhook on your deploy.
STRIPE_WEBHOOK_SECRET=
# Output of `npm run stripe:setup` (creates the Pulpo Pro product +
# default monthly price). Idempotent — safe to re-run.
STRIPE_PRICE_ID_PRO=

# --- Telemetry (PostHog) --------------------------------------------------
# Project key from https://eu.posthog.com → Project settings → API keys.
# Without a key, every track() call is a no-op (CI, fresh clones).
VITE_POSTHOG_KEY=
# Override only if not on PostHog Cloud EU. Defaults to https://eu.i.posthog.com
VITE_POSTHOG_HOST=
# Personal API key (PostHog → Personal API keys). Only used by the DSR
# tooling at scripts/dsr/* — Person-read + Person-delete require a
# personal key, not a project key. NEVER set this in Vercel env vars
# (server functions don't need it; only Sebas's laptop does).
POSTHOG_PERSONAL_API_KEY=
# Numeric project ID from the PostHog URL (e.g. 12345 in
# /project/12345/...). Only used by scripts/dsr/*.
POSTHOG_PROJECT_ID=

# --- Diagnostic flags ------------------------------------------------------
# Off by default. Flip to "1" in Vercel env when triaging an auth
# regression — turns on verbose `[api] clerk.authReq` lines in
# api/_clerk.js. Keep off in steady state so Vercel runtime logs don't
# bloat. Logs cookie *names* and a session-cookie boolean only — never
# values, never the full URL (path only, query strings stripped).
PULPO_DEBUG_AUTH=

# --- Phase 4 U3 — LLM-vision aesthetic booster ----------------------------
# Default OFF. With these unset, hero re-escalation uses today's
# PR-7.6 compute_score + detect_text_overlay path only. To opt in:
#   1. Pick a provider and set its key:
#      - Qwen3-VL Flash via Alibaba DashScope (cheapest, but Alibaba
#        account required):
#          QWEN_API_KEY=sk-...
#      - Qwen3-VL Flash via Segmind (third-party host of the same model;
#        easier signup; single account-level key covers every Segmind
#        model):
#          SEGMIND_API_KEY=...
#      - OpenAI gpt-4o-mini vision:
#          OPENAI_API_KEY=sk-...
#      - Anthropic claude-haiku-4-5 vision:
#          ANTHROPIC_API_KEY=sk-ant-...
#   2. Flip LLM_VISION_ENABLED=true at runtime.
# When set, each candidate gets a 0-10 aesthetic score that composites
# with the technical score (70% aesthetic + 30% technical) to drive
# hero selection. Daily USD cap tracked in
# web/data/llm_vision_budget.jsonl; exhaustion falls back to technical-
# only ranking, no error to the operator. Per-image scores are cached
# in web/data/llm_vision_cache.json (sha1(bytes) → score) so re-runs
# don't re-pay for previously-scored photos.
# LLM_VISION_ENABLED=false
# LLM_VISION_PROVIDER=qwen   # or "segmind" / "openai" / "anthropic"
# LLM_VISION_DAILY_BUDGET_USD=1.00
# Per-call cost estimate used for budget tracking. Defaults are
# provider-aware ($0.0006 qwen, $0.0008 segmind, $0.0008 openai-mini,
# $0.001 anthropic-haiku). Override only when your account's pricing
# differs from these published estimates.
# LLM_VISION_COST_PER_CALL_USD=0.0006
# DashScope OpenAI-compatible endpoint — only override for a region
# mirror or a self-hosted gateway.
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_VISION_MODEL=qwen3-vl-flash
# Segmind endpoint — model name is embedded in the URL path. The
# defaults match Segmind's docs at
# https://www.segmind.com/models/qwen3-vl-flash/api
# SEGMIND_BASE_URL=https://api.segmind.com/v1
# SEGMIND_VISION_MODEL=qwen3-vl-flash

# Top-X% gating: only the cheapest-quality-score top N% of *uncached*
# candidates across a nightly run get a paid VLM call. Default 5.
# Set higher to score more candidates per run; set lower to clamp
# spend; set 100 to score every uncached candidate (legacy behavior).
# Cached candidates (recurring photos) always reuse their cached score
# for free regardless of this knob.
# LLM_VISION_TOP_PCT=5
