# Environment + secrets
.env
.env.local

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/

# Vite build output — Vercel rebuilds on deploy; locals don't track it
web/dist/

# Vercel build cache
.vercel/

# Calibration samples — saved HTML can contain personal cookie data,
# session-tagged URLs, and unredacted broker contact info that we don't
# want in version control. The selectors live in code; the HTML doesn't.
samples/calibration/*/*.html
# Exceptions: calibrated source fixtures used by pytest (public listings, no PII)
!samples/calibration/goodlife/*.html
!samples/calibration/oceanside/*.html
!samples/calibration/nexo/*.html
!samples/calibration/realtyelsalvador/*.html
!samples/calibration/bienesraices/*.html
!samples/calibration/century21/*.html
!samples/calibration/encuentra24/*.html

# OS junk
.DS_Store
Thumbs.db
.vercel
.env*.local

# Claude Code workspace (per-user, agent worktrees, local settings)
.claude/

# Category-image masters — heavy PNG sources kept locally for re-export only.
# The optimized WebPs live in web/app/assets/categories/ and are committed.
category_imgs/

# Playwright trace artefacts + scratch screenshots dropped at repo root by
# ad-hoc tool runs.
.playwright-mcp/
test-results/
desktop-discover.png
mobile-discover.png
.gstack/
