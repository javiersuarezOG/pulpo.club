    <title>@lottiefiles/dotlottie-web | basic example</title>
  </head>
  <body>
    <!-- Canvas element where the Lottie animation will be rendered -->
    <div
      style="display: flex; flex-direction: column; align-items: center; width: 100%; height: 100vh; justify-content: center"
    >
      <canvas
        id="canvas"
        width="250"
        height="250"
        style="width: 250px; height: 250px;"
      ></canvas>
    </div>
    <script type="module">
      import { DotLottie } from 'https://cdn.jsdelivr.net/npm/@lottiefiles/dotlottie-web/+esm';

      new DotLottie({
        autoplay: true,
        loop: true,
        canvas: document.getElementById('canvas'),
        src: '/kazu.json', // or .json file
      });
    </script>
  </body>
